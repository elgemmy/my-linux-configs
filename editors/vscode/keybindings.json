// ╔══════════════════════════════════════════════════════════════════════════════════╗
// ║  GEMMY'S VSCODE KEYBINDINGS — Keyboard-First, Vim-Layered                     ║
// ║  Consistent with Hyprland/Kitty mental model                                  ║
// ╚══════════════════════════════════════════════════════════════════════════════════╝
//
// LAYER PHILOSOPHY:
//   Ctrl+{hjkl}  → Navigate between zones (splits, panels)    [like Hyprland]
//   Alt+{hjkl}   → Move/resize things within zones            [like Hyprland]
//   Shift+{HL}   → Cycle tabs (prev/next buffer)              [LazyVim style]
//   Ctrl+{key}   → Global workspace actions (toggle panels, search, files)
//   Ctrl+W chord → Window management (split, close, move)     [Vim :wincmd]
//   [ ] brackets → Jump between diagnostics, git hunks, etc.  [LazyVim unimpaired]
//
// WHEN CLAUSES KEY:
//   vim.mode != 'Insert'   → only in Normal/Visual (won't break typing)
//   !terminalFocus          → let terminal handle its own keys
//   !suggestWidgetVisible   → let autocomplete use j/k
//   !inQuickOpen            → let Ctrl+P menu use j/k
//
// NOTE: Leader-key (<Space>) bindings belong in settings.json under
//       vim.normalModeKeyBindingsNonRecursive, NOT here.
//
[
    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 1. ZONE NAVIGATION — Ctrl+H/J/K/L                                            │
    // │    Move focus between editor groups, terminal, sidebars                       │
    // │    Mirrors: Hyprland movefocus, Tmux pane switching                           │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "ctrl+h",
        "command": "workbench.action.focusLeftGroup",
        "when": "!terminalFocus && vim.active && vim.mode != 'Insert'"
    },
    {
        "key": "ctrl+l",
        "command": "workbench.action.focusRightGroup",
        "when": "!terminalFocus && vim.active && vim.mode != 'Insert'"
    },
    {
        "key": "ctrl+j",
        "command": "workbench.action.focusBelowGroup",
        "when": "!terminalFocus && !suggestWidgetVisible && !inQuickOpen && vim.active && vim.mode != 'Insert'"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.focusAboveGroup",
        "when": "!terminalFocus && !suggestWidgetVisible && !inQuickOpen && vim.active && vim.mode != 'Insert'"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 2. BUFFER/TAB CYCLING — Shift+H / Shift+L                                    │
    // │    Previous/next editor tab (LazyVim convention)                              │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "shift+h",
        "command": "workbench.action.previousEditor",
        "when": "vim.active && vim.mode != 'Insert' && editorTextFocus"
    },
    {
        "key": "shift+l",
        "command": "workbench.action.nextEditor",
        "when": "vim.active && vim.mode != 'Insert' && editorTextFocus"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 3. LINE MOVEMENT — Alt+J / Alt+K                                              │
    // │    Move lines up/down (works in both Normal and Visual)                       │
    // │    Mirrors: Alt in Hyprland = "manipulate within zone"                        │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "alt+j",
        "command": "editor.action.moveLinesDownAction",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "alt+k",
        "command": "editor.action.moveLinesUpAction",
        "when": "editorTextFocus && !editorReadonly"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 4. SPLIT RESIZING — Ctrl+Arrow Keys                                           │
    // │    Resize editor groups (only in Normal mode to not break word-jump)          │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "ctrl+up",
        "command": "workbench.action.increaseViewHeight",
        "when": "editorTextFocus && vim.active && vim.mode == 'Normal'"
    },
    {
        "key": "ctrl+down",
        "command": "workbench.action.decreaseViewHeight",
        "when": "editorTextFocus && vim.active && vim.mode == 'Normal'"
    },
    {
        "key": "ctrl+left",
        "command": "workbench.action.decreaseViewWidth",
        "when": "editorTextFocus && vim.active && vim.mode == 'Normal'"
    },
    {
        "key": "ctrl+right",
        "command": "workbench.action.increaseViewWidth",
        "when": "editorTextFocus && vim.active && vim.mode == 'Normal'"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 5. WINDOW MANAGEMENT — Ctrl+W chords (native Vim :wincmd)                     │
    // │    Split, close, move editors between groups                                  │
    // └────────────────────────────────────────────────────────────────────────────────┘
    // Note: Ctrl+W is passed through to vim in your handleKeys, re-enable it:
    // In settings.json, change "<C-w>": false → remove it or set true
    // Then these Ctrl+W chords become available:
    {
        "key": "ctrl+w v",
        "command": "workbench.action.splitEditorRight",
        "when": "vim.active && vim.mode == 'Normal'"
    },
    {
        "key": "ctrl+w s",
        "command": "workbench.action.splitEditorDown",
        "when": "vim.active && vim.mode == 'Normal'"
    },
    {
        "key": "ctrl+w q",
        "command": "workbench.action.closeActiveEditor",
        "when": "vim.active && vim.mode == 'Normal'"
    },
    {
        "key": "ctrl+w o",
        "command": "workbench.action.closeOtherEditors",
        "when": "vim.active && vim.mode == 'Normal'"
    },
    {
        "key": "ctrl+w l",
        "command": "workbench.action.moveEditorToRightGroup",
        "when": "vim.active && vim.mode == 'Normal' && editorTextFocus"
    },
    {
        "key": "ctrl+w h",
        "command": "workbench.action.moveEditorToLeftGroup",
        "when": "vim.active && vim.mode == 'Normal' && editorTextFocus"
    },
    {
        "key": "ctrl+w j",
        "command": "workbench.action.moveEditorToBelowGroup",
        "when": "vim.active && vim.mode == 'Normal' && editorTextFocus"
    },
    {
        "key": "ctrl+w k",
        "command": "workbench.action.moveEditorToAboveGroup",
        "when": "vim.active && vim.mode == 'Normal' && editorTextFocus"
    },
    // Toggle split layout horizontal ↔ vertical
    {
        "key": "ctrl+w space",
        "command": "workbench.action.toggleEditorGroupLayout",
        "when": "vim.active && vim.mode == 'Normal'"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 6. PANEL & SIDEBAR TOGGLES — Ctrl+{key}                                      │
    // │    Your existing bindings, cleaned up + additions                             │
    // └────────────────────────────────────────────────────────────────────────────────┘
    // Toggle bottom panel (terminal, output, problems)
    {
        "key": "ctrl+j",
        "command": "workbench.action.togglePanel",
        "when": "vim.mode == 'Insert' || !vim.active || terminalFocus"
    },
    // Focus terminal directly
    {
        "key": "ctrl+shift+enter",
        "command": "workbench.action.terminal.focus"
    },
    // From terminal → back to editor
    {
        "key": "ctrl+;",
        "command": "workbench.action.focusActiveEditorGroup"
    },
    // Toggle primary sidebar (explorer, git, extensions)
    {
        "key": "ctrl+e",
        "command": "workbench.action.toggleSidebarVisibility"
    },
    // Focus file explorer specifically
    {
        "key": "ctrl+y",
        "command": "workbench.files.action.focusFilesExplorer"
    },
    // Toggle secondary sidebar (auxiliary bar: Copilot, Claude Code panel)
    {
        "key": "ctrl+'",
        "command": "workbench.action.toggleAuxiliaryBar"
    },
    // Focus auxiliary bar
    {
        "key": "ctrl+shift+'",
        "command": "workbench.action.focusAuxiliaryBar"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 7. TERMINAL — Enhanced keyboard control                                       │
    // └────────────────────────────────────────────────────────────────────────────────┘
    // Line continuation in terminal (your existing binding)
    {
        "key": "shift+enter",
        "command": "workbench.action.terminal.sendSequence",
        "args": { "text": "\\\r\n" },
        "when": "terminalFocus"
    },
    // New terminal instance
    {
        "key": "ctrl+shift+n",
        "command": "workbench.action.terminal.new",
        "when": "terminalFocus"
    },
    // Cycle terminals (like tab cycling)
    {
        "key": "ctrl+shift+j",
        "command": "workbench.action.terminal.focusNext",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+shift+k",
        "command": "workbench.action.terminal.focusPrevious",
        "when": "terminalFocus"
    },
    // Kill terminal
    {
        "key": "ctrl+shift+w",
        "command": "workbench.action.terminal.kill",
        "when": "terminalFocus"
    },
    // Split terminal
    {
        "key": "ctrl+\\",
        "command": "workbench.action.terminal.split",
        "when": "terminalFocus"
    },
    // Toggle terminal maximize
    {
        "key": "ctrl+shift+m",
        "command": "workbench.action.toggleMaximizedPanel",
        "when": "terminalFocus || panelFocus"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 8. AUTOCOMPLETE & QUICK OPEN — j/k navigation                                │
    // │    Use Ctrl+J/K to navigate suggestions and quick open like vim               │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "ctrl+j",
        "command": "selectNextSuggestion",
        "when": "suggestWidgetVisible"
    },
    {
        "key": "ctrl+k",
        "command": "selectPrevSuggestion",
        "when": "suggestWidgetVisible"
    },
    {
        "key": "ctrl+j",
        "command": "workbench.action.quickOpenSelectNext",
        "when": "inQuickOpen"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.quickOpenSelectPrevious",
        "when": "inQuickOpen"
    },
    // Same for parameter hints
    {
        "key": "ctrl+j",
        "command": "showNextParameterHint",
        "when": "editorFocus && parameterHintsVisible"
    },
    {
        "key": "ctrl+k",
        "command": "showPrevParameterHint",
        "when": "editorFocus && parameterHintsVisible"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 9. FILE EXPLORER — Vim-like keys when explorer is focused                     │
    // └────────────────────────────────────────────────────────────────────────────────┘
    // Create new file
    {
        "key": "a",
        "command": "explorer.newFile",
        "when": "filesExplorerFocus && !inputFocus"
    },
    // Create new folder
    {
        "key": "shift+a",
        "command": "explorer.newFolder",
        "when": "filesExplorerFocus && !inputFocus"
    },
    // Rename
    {
        "key": "r",
        "command": "renameFile",
        "when": "filesExplorerFocus && !inputFocus"
    },
    // Delete
    {
        "key": "d",
        "command": "deleteFile",
        "when": "filesExplorerFocus && !inputFocus"
    },
    // Copy file
    {
        "key": "y",
        "command": "filesExplorer.copy",
        "when": "filesExplorerFocus && !inputFocus"
    },
    // Paste file
    {
        "key": "p",
        "command": "filesExplorer.paste",
        "when": "filesExplorerFocus && !inputFocus"
    },
    // Cut file (move)
    {
        "key": "x",
        "command": "filesExplorer.cut",
        "when": "filesExplorerFocus && !inputFocus"
    },
    // Collapse all in explorer
    {
        "key": "shift+h",
        "command": "workbench.files.action.collapseExplorerFolders",
        "when": "filesExplorerFocus && !inputFocus"
    },
    // Open file to the side (split)
    {
        "key": "ctrl+enter",
        "command": "explorer.openToSide",
        "when": "filesExplorerFocus && !inputFocus"
    },
    // Escape back to editor from explorer
    {
        "key": "escape",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "filesExplorerFocus"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 10. DIAGNOSTIC NAVIGATION — [d / ]d and [e / ]e                               │
    // │     Jump between errors/warnings (unimpaired style)                           │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "oem_6 d",
        "command": "editor.action.marker.next",
        "when": "editorTextFocus && vim.mode == 'Normal'"
    },
    {
        "key": "oem_4 d",
        "command": "editor.action.marker.prev",
        "when": "editorTextFocus && vim.mode == 'Normal'"
    },
    // Errors only
    {
        "key": "oem_6 e",
        "command": "editor.action.marker.nextInFiles",
        "when": "editorTextFocus && vim.mode == 'Normal'"
    },
    {
        "key": "oem_4 e",
        "command": "editor.action.marker.prevInFiles",
        "when": "editorTextFocus && vim.mode == 'Normal'"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 11. GIT HUNK NAVIGATION — [c / ]c                                             │
    // │     Jump between git changes (c for "change")                                │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "oem_6 c",
        "command": "workbench.action.editor.nextChange",
        "when": "editorTextFocus && vim.mode == 'Normal'"
    },
    {
        "key": "oem_4 c",
        "command": "workbench.action.editor.previousChange",
        "when": "editorTextFocus && vim.mode == 'Normal'"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 12. CODE ACTIONS & INTELLIGENCE — Quick access                                │
    // └────────────────────────────────────────────────────────────────────────────────┘
    // Quick fix / code action (also available via <leader>ca in vim bindings)
    {
        "key": "ctrl+.",
        "command": "editor.action.quickFix",
        "when": "editorTextFocus"
    },
    // Peek definition without leaving current file
    {
        "key": "alt+d",
        "command": "editor.action.peekDefinition",
        "when": "editorTextFocus && vim.mode == 'Normal'"
    },
    // Go back / forward in navigation history (Alt+arrows like browsers)
    // These are VSCode defaults, listed for documentation
    // alt+left  → workbench.action.navigateBack
    // alt+right → workbench.action.navigateForward

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 13. SEARCH & LISTS — j/k navigation in all list-like widgets                  │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "ctrl+j",
        "command": "list.focusDown",
        "when": "listFocus && !inputFocus"
    },
    {
        "key": "ctrl+k",
        "command": "list.focusUp",
        "when": "listFocus && !inputFocus"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 14. ZENMODE & FOCUS                                                            │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "ctrl+shift+z",
        "command": "workbench.action.toggleZenMode"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 15. DISABLE CONFLICTING DEFAULTS                                               │
    // │     Unbind VSCode defaults that clash with our vim layer                      │
    // └────────────────────────────────────────────────────────────────────────────────┘
    // Ctrl+J default is "toggle panel" globally — we handle it contextually above
    {
        "key": "ctrl+j",
        "command": "-workbench.action.togglePanel"
    },
    // Ctrl+K is a chord prefix for many things — disable the solo version
    // so it doesn't interfere with our navigate-up binding
    {
        "key": "ctrl+k",
        "command": "-extension.vim_ctrl+k",
        "when": "editorTextFocus && vim.active && vim.use<C-k> && !inDebugRepl"
    },
    // Ctrl+E default opens recent files — we use it for sidebar toggle
    {
        "key": "ctrl+e",
        "command": "-workbench.action.quickOpen"
    },
    // Shift+H/L in vim normally go to screen top/bottom — override for tab nav
    {
        "key": "shift+h",
        "command": "-extension.vim_shift+h",
        "when": "editorTextFocus && vim.active"
    },
    {
        "key": "shift+l",
        "command": "-extension.vim_shift+l",
        "when": "editorTextFocus && vim.active"
    },
]