// ╔══════════════════════════════════════════════════════════════════════════════════╗
// ║  CURSOR KEYBINDINGS — Keyboard-First, Vim-Layered + AI-safe                    ║
// ║  Inherits VSCode muscle-memory map, then layers Cursor AI without clashes       ║
// ╚══════════════════════════════════════════════════════════════════════════════════╝
[
    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 1. ZONE NAVIGATION — Ctrl+H/J/K/L                                            │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "ctrl+h",
        "command": "workbench.action.focusLeftGroup",
        "when": "!terminalFocus && vim.active && vim.mode != 'Insert'"
    },
    {
        "key": "ctrl+l",
        "command": "workbench.action.focusRightGroup",
        "when": "!terminalFocus && vim.active && vim.mode != 'Insert'"
    },
    {
        "key": "ctrl+j",
        "command": "workbench.action.focusBelowGroup",
        "when": "!terminalFocus && !suggestWidgetVisible && !inQuickOpen && vim.active && vim.mode != 'Insert'"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.focusAboveGroup",
        "when": "!terminalFocus && !suggestWidgetVisible && !inQuickOpen && vim.active && vim.mode != 'Insert'"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 2. BUFFER/TAB CYCLING — Shift+H / Shift+L                                    │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "shift+h",
        "command": "workbench.action.previousEditor",
        "when": "vim.active && vim.mode != 'Insert' && editorFocus && !terminalFocus"
    },
    {
        "key": "shift+l",
        "command": "workbench.action.nextEditor",
        "when": "vim.active && vim.mode != 'Insert' && editorFocus && !terminalFocus"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 3. LINE MOVEMENT — Alt+J / Alt+K                                              │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "alt+j",
        "command": "editor.action.moveLinesDownAction",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "alt+k",
        "command": "editor.action.moveLinesUpAction",
        "when": "editorTextFocus && !editorReadonly"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 4. SPLIT RESIZING — Ctrl+Arrow Keys                                           │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "ctrl+up",
        "command": "workbench.action.increaseViewHeight",
        "when": "vim.active && vim.mode == 'Normal'"
    },
    {
        "key": "ctrl+down",
        "command": "workbench.action.decreaseViewHeight",
        "when": "vim.active && vim.mode == 'Normal'"
    },
    {
        "key": "ctrl+left",
        "command": "workbench.action.decreaseViewWidth",
        "when": "vim.active && vim.mode == 'Normal'"
    },
    {
        "key": "ctrl+right",
        "command": "workbench.action.increaseViewWidth",
        "when": "vim.active && vim.mode == 'Normal'"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 5. WINDOW MANAGEMENT — Ctrl+W chords                                          │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "ctrl+w v",
        "command": "workbench.action.splitEditorRight",
        "when": "vim.active && vim.mode == 'Normal'"
    },
    {
        "key": "ctrl+w s",
        "command": "workbench.action.splitEditorDown",
        "when": "vim.active && vim.mode == 'Normal'"
    },
    {
        "key": "ctrl+w q",
        "command": "workbench.action.closeActiveEditor",
        "when": "vim.active && vim.mode == 'Normal'"
    },
    {
        "key": "ctrl+w o",
        "command": "workbench.action.closeOtherEditors",
        "when": "vim.active && vim.mode == 'Normal'"
    },
    {
        "key": "ctrl+w l",
        "command": "workbench.action.moveEditorToRightGroup",
        "when": "vim.active && vim.mode == 'Normal' && editorTextFocus"
    },
    {
        "key": "ctrl+w h",
        "command": "workbench.action.moveEditorToLeftGroup",
        "when": "vim.active && vim.mode == 'Normal' && editorTextFocus"
    },
    {
        "key": "ctrl+w j",
        "command": "workbench.action.moveEditorToBelowGroup",
        "when": "vim.active && vim.mode == 'Normal' && editorTextFocus"
    },
    {
        "key": "ctrl+w k",
        "command": "workbench.action.moveEditorToAboveGroup",
        "when": "vim.active && vim.mode == 'Normal' && editorTextFocus"
    },
    {
        "key": "ctrl+w space",
        "command": "workbench.action.toggleEditorGroupLayout",
        "when": "vim.active && vim.mode == 'Normal'"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 6. PANELS & SIDEBARS                                                          │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "ctrl+j",
        "command": "workbench.action.togglePanel",
        "when": "vim.mode == 'Insert' || !vim.active || terminalFocus"
    },
    {
        "key": "ctrl+shift+enter",
        "command": "workbench.action.terminal.focus"
    },
    {
        "key": "ctrl+;",
        "command": "workbench.action.focusActiveEditorGroup"
    },
    {
        "key": "ctrl+e",
        "command": "workbench.action.toggleSidebarVisibility"
    },
    {
        "key": "ctrl+y",
        "command": "workbench.files.action.focusFilesExplorer"
    },
    {
        "key": "ctrl+'",
        "command": "workbench.action.toggleAuxiliaryBar"
    },
    {
        "key": "ctrl+shift+'",
        "command": "workbench.action.focusAuxiliaryBar"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 7. TERMINAL                                                                    │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "shift+enter",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\\\r\n"
        },
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+shift+n",
        "command": "workbench.action.terminal.new",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+shift+j",
        "command": "workbench.action.terminal.focusNext",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+shift+k",
        "command": "workbench.action.terminal.focusPrevious",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+shift+w",
        "command": "workbench.action.terminal.kill",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+\\",
        "command": "workbench.action.terminal.split",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+shift+m",
        "command": "workbench.action.toggleMaximizedPanel",
        "when": "terminalFocus || panelFocus"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 8. AUTOCOMPLETE / QUICK OPEN / LIST NAV                                       │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "ctrl+j",
        "command": "selectNextSuggestion",
        "when": "suggestWidgetVisible"
    },
    {
        "key": "ctrl+k",
        "command": "selectPrevSuggestion",
        "when": "suggestWidgetVisible"
    },
    {
        "key": "ctrl+j",
        "command": "workbench.action.quickOpenSelectNext",
        "when": "inQuickOpen"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.quickOpenSelectPrevious",
        "when": "inQuickOpen"
    },
    {
        "key": "ctrl+j",
        "command": "showNextParameterHint",
        "when": "editorFocus && parameterHintsVisible"
    },
    {
        "key": "ctrl+k",
        "command": "showPrevParameterHint",
        "when": "editorFocus && parameterHintsVisible"
    },
    {
        "key": "ctrl+j",
        "command": "list.focusDown",
        "when": "listFocus && !inputFocus"
    },
    {
        "key": "ctrl+k",
        "command": "list.focusUp",
        "when": "listFocus && !inputFocus"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 9. FILE EXPLORER KEYS                                                         │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "a",
        "command": "explorer.newFile",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "shift+a",
        "command": "explorer.newFolder",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "r",
        "command": "renameFile",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "d",
        "command": "deleteFile",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "y",
        "command": "filesExplorer.copy",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "p",
        "command": "filesExplorer.paste",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "x",
        "command": "filesExplorer.cut",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "shift+h",
        "command": "workbench.files.action.collapseExplorerFolders",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "ctrl+enter",
        "command": "explorer.openToSide",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "escape",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "filesExplorerFocus"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 10. DIAGNOSTICS / GIT CHANGE JUMPS                                            │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "oem_6 d",
        "command": "editor.action.marker.next",
        "when": "editorTextFocus && vim.mode == 'Normal'"
    },
    {
        "key": "oem_4 d",
        "command": "editor.action.marker.prev",
        "when": "editorTextFocus && vim.mode == 'Normal'"
    },
    {
        "key": "oem_6 e",
        "command": "editor.action.marker.nextInFiles",
        "when": "editorTextFocus && vim.mode == 'Normal'"
    },
    {
        "key": "oem_4 e",
        "command": "editor.action.marker.prevInFiles",
        "when": "editorTextFocus && vim.mode == 'Normal'"
    },
    {
        "key": "oem_6 c",
        "command": "workbench.action.editor.nextChange",
        "when": "editorTextFocus && vim.mode == 'Normal'"
    },
    {
        "key": "oem_4 c",
        "command": "workbench.action.editor.previousChange",
        "when": "editorTextFocus && vim.mode == 'Normal'"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 11. CODE ACTIONS / FOCUS                                                      │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "ctrl+.",
        "command": "editor.action.quickFix",
        "when": "editorTextFocus"
    },
    {
        "key": "alt+d",
        "command": "editor.action.peekDefinition",
        "when": "editorTextFocus && vim.mode == 'Normal'"
    },
    {
        "key": "ctrl+shift+z",
        "command": "workbench.action.toggleZenMode"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 12. CURSOR AI LAYER — left-hand Ctrl+Alt, right-hand action keys               │
    // │    Mnemonic: O=agent (Composer mode), I=inline, L=chat, K=Composer focus      │
    // │    Ctrl+K / Ctrl+L defaults are unbound below so Vim zone nav stays clean.    │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "ctrl+alt+o",
        "command": "composerMode.agent"
    },
    {
        "key": "ctrl+alt+k",
        "command": "composer.focusComposer"
    },
    {
        "key": "ctrl+alt+i",
        "command": "aipopup.action.modal.generate",
        "when": "editorFocus"
    },
    {
        "key": "ctrl+alt+l",
        "command": "workbench.action.chat.open"
    },
    // Keep Vim-navigation-safe unbinds for Cursor defaults.
    {
        "key": "ctrl+k",
        "command": "-aipopup.action.modal.generate",
        "when": "editorFocus"
    },
    {
        "key": "ctrl+l",
        "command": "-workbench.action.chat.open"
    },
    {
        "key": "ctrl+alt+/",
        "command": "workbench.action.chat.openModelPicker",
        "when": "editorFocus || panelFocus"
    },

    // ┌────────────────────────────────────────────────────────────────────────────────┐
    // │ 13. DISABLE CONFLICTING DEFAULTS                                              │
    // └────────────────────────────────────────────────────────────────────────────────┘
    {
        "key": "ctrl+j",
        "command": "-workbench.action.togglePanel"
    },
    {
        "key": "ctrl+k",
        "command": "-extension.vim_ctrl+k",
        "when": "editorTextFocus && vim.active && vim.use<C-k> && !inDebugRepl"
    },
    {
        "key": "ctrl+e",
        "command": "-workbench.action.quickOpen"
    },
    {
        "key": "shift+h",
        "command": "-extension.vim_shift+h",
        "when": "editorFocus && vim.active"
    },
    {
        "key": "shift+l",
        "command": "-extension.vim_shift+l",
        "when": "editorFocus && vim.active"
    }
]