# Bitwarden + GitHub credential integration
bw-unlock() {
    echo "Unlocking Bitwarden..."
    export BW_SESSION="$(bw unlock --raw)"
    if [[ -n "$BW_SESSION" ]]; then
        echo "Bitwarden unlocked for this terminal session."
    else
        echo "Failed to unlock Bitwarden." >&2
        return 1
    fi
}

# Lazy gh wrapper: fetches GH_TOKEN from Bitwarden on first use
gh() {
    if [[ -z "$GH_TOKEN" ]]; then
        if [[ -z "$BW_SESSION" ]]; then
            echo "Run 'bw-unlock' first to unlock Bitwarden." >&2
            return 1
        fi
        export GH_TOKEN="$(bw get password 'GitHub PAT' 2>/dev/null)"
        if [[ -z "$GH_TOKEN" ]]; then
            echo "Failed to fetch GitHub PAT from Bitwarden." >&2
            return 1
        fi
    fi
    command gh "$@"
}

