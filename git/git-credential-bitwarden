#!/usr/bin/env bash
# Git credential helper that fetches GitHub PAT from Bitwarden.
# Requires BW_SESSION to be set (run 'bw-unlock' once per terminal session).

case "$1" in
    get)  ;;
    *)    exit 0 ;;
esac

# Read the request from git (stdin: key=value lines)
host=""
protocol=""
while IFS='=' read -r key value; do
    case "$key" in
        host)     host="$value" ;;
        protocol) protocol="$value" ;;
    esac
done

# Only handle github.com over https
[[ "$host" != "github.com" || "$protocol" != "https" ]] && exit 0

if [[ -z "$BW_SESSION" ]]; then
    echo "git-credential-bitwarden: BW_SESSION not set. Run 'bw-unlock' first." >&2
    exit 1
fi

token="$(bw get password 'GitHub PAT' 2>/dev/null)"
if [[ -z "$token" ]]; then
    echo "git-credential-bitwarden: failed to retrieve GitHub PAT from Bitwarden." >&2
    exit 1
fi

printf 'protocol=https\nhost=github.com\nusername=el_gemmmy\npassword=%s\n' "$token"
