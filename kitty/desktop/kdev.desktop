[Desktop Entry]
Version=1.0
Type=Application
Name=kdev
GenericName=Kitty daily session
Comment=Open the daily Kitty development session
TryExec=sh
StartupNotify=true
Exec=sh -lc "exec kitty --class kdev --detach --session ${XDG_CONFIG_HOME:-$HOME/.config}/kitty/sessions/daily.kitty-session"
Icon=kitty
Categories=System;TerminalEmulator;
Keywords=kitty;kdev;daily;development;session;terminal;
StartupWMClass=kdev
