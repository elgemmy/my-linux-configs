[Desktop Entry]
Version=1.0
Type=Application
Name=kdev
GenericName=Kitty daily session
Comment=Open the daily Kitty development session
TryExec=__KITTY__
StartupNotify=true
Exec=__KITTY__ --class kdev --detach --session __HOME__/.config/kitty/sessions/daily.kitty-session
Icon=kitty
Categories=System;TerminalEmulator;
Keywords=kitty;kdev;daily;development;session;terminal;
StartupWMClass=kdev
