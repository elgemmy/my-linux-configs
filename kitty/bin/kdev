#!/usr/bin/env bash
set -Eeuo pipefail

config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
default_session="$config_home/kitty/sessions/daily.kitty-session"
local_session="$config_home/kitty/sessions/kdev.local.kitty-session"
if [[ -n ${KDEV_SESSION:-} ]]; then
  session=$KDEV_SESSION
elif [[ -r $local_session ]]; then
  session=$local_session
else
  session=$default_session
fi
log_dir="$state_home/linux-config"
log_file="$log_dir/kdev.log"
kitty_bin="$HOME/.local/kitty.app/bin/kitty"

if [[ ${1:-} == --check ]]; then
  failures=0
  if [[ -x $kitty_bin ]]; then
    printf 'OK kitty: %s\n' "$kitty_bin"
  else
    printf 'FAIL kitty is not executable: %s\n' "$kitty_bin" >&2
    failures=$((failures + 1))
  fi
  if [[ -r $session ]]; then
    printf 'OK session: %s\n' "$session"
  else
    printf 'FAIL session is not readable: %s\n' "$session" >&2
    failures=$((failures + 1))
  fi
  printf 'INFO launch log: %s\n' "$log_file"
  ((failures == 0))
  exit
fi

mkdir -p "$log_dir"
{
  printf '\n[%s] Starting KDev session\n' "$(date --iso-8601=seconds)"
  echo "Kitty: $kitty_bin"
  echo "Session: $session"
} >> "$log_file"

if [[ ! -x $kitty_bin ]]; then
  message="Kitty is not executable: $kitty_bin"
  echo "ERROR: $message" >> "$log_file"
  command -v notify-send >/dev/null 2>&1 &&
    notify-send 'KDev failed to start' "$message. See $log_file"
  exit 1
fi
if [[ ! -r $session ]]; then
  message="Session is not readable: $session"
  echo "ERROR: $message" >> "$log_file"
  command -v notify-send >/dev/null 2>&1 &&
    notify-send 'KDev failed to start' "$message. See $log_file"
  exit 1
fi

if "$kitty_bin" --class kdev --session "$session" >> "$log_file" 2>&1; then
  exit 0
else
  rc=$?
fi

message="Kitty exited with status $rc"
echo "ERROR: $message" >> "$log_file"
command -v notify-send >/dev/null 2>&1 &&
  notify-send 'KDev failed to start' "$message. See $log_file"
exit "$rc"
